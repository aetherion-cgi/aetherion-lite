# Aetherion AI Agents - Environment Configuration

# Required: Anthropic API Key
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Database connection (for production)
DATABASE_URL=postgresql://user:password@localhost:5432/aetherion

# Optional: External API keys (for UDOA)
FRED_API_KEY=your-fred-api-key
WORLD_BANK_API_KEY=your-worldbank-key

# Optional: Service endpoints
GOVERNANCE_ENDPOINT=http://localhost:8002/governance
ILE_ENDPOINT=http://localhost:8007/ile
