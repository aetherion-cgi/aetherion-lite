# BUE ULTIMATE 10/10 - ENVIRONMENT CONFIGURATION

# Application
ENV=production
DEBUG=false
LOG_LEVEL=INFO

# Feature Flags (10/10 Capabilities)
ENABLE_GPU=true
ENABLE_STREAMING=true
ENABLE_FORECASTING=true
ENABLE_DEVICE_MESH=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=https://api.aetherion.ai/bue

# Database (PostgreSQL)
DATABASE_URL=postgresql://bue:bue_password@localhost:5432/bue

# Cache (Redis)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# GPU Configuration
GPU_DEVICE_ID=0
GPU_MEMORY_FRACTION=0.8

# Monte Carlo Defaults
DEFAULT_SIMULATIONS=10000
GPU_SIMULATIONS=1000000

# Forecasting
DEFAULT_HORIZON_MONTHS=36
FORECAST_MODELS=arima,prophet,lstm

# Authentication & Security
JWT_SECRET_KEY=your-secret-key-here-min-32-chars

# Deployment Jurisdiction
DEPLOYMENT_JURISDICTION=sandbox
ALLOWED_COUNTRIES=USA,GBR,CAN,AUS,SGP,JPN,CHE,NZL
